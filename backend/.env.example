# ==========================================================================
# Spring Boot Environment Configurations
# Copy this file to '.env' and fill in your values.
# ==========================================================================

SPRING_PROFILES_ACTIVE=dev

SERVER_PORT=8080

# Database (only needed for prod profile)
DATABASE_URL=jdbc:postgresql://localhost:5432/novaforms
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Gemini AI (optional — AI features degrade gracefully without it)
GEMINI_API_KEY=

# Cloudinary (optional — file uploads won't work without it)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Host URLs
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

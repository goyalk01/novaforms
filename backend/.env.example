# ==========================================================================
# Spring Boot Production Environment Configurations
# Copy this file to '.env' or use these keys in your hosting platform dashboard.
# ==========================================================================

# Server configuration
SERVER_PORT=8080

# Database configurations (Supports Postgres / Neon PostgreSQL URIs out-of-the-box)
DATABASE_URL=postgres://sa:password@localhost:5432/novaforms
DATABASE_USERNAME=sa
DATABASE_PASSWORD=password

# Production host routes
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
